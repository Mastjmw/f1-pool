generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  picks         Pick[]
  poolMembers   PoolMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── F1 Pool ─────────────────────────────────────────────

model Pool {
  id          String       @id @default(cuid())
  name        String
  season      Int          @default(2026)
  midReset    Boolean      @default(false)
  resetAfter  Int?
  inviteCode  String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  members     PoolMember[]
  picks       Pick[]
}

model PoolMember {
  id        String   @id @default(cuid())
  userId    String
  poolId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool      Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId])
}

model Driver {
  id          String   @id @default(cuid())
  externalId  String   @unique
  code        String
  name        String
  team        String
  number      Int
  season      Int      @default(2026)
  picks       Pick[]
  results     RaceResult[]
}

model Race {
  id           String       @id @default(cuid())
  season       Int          @default(2026)
  round        Int
  name         String
  circuit      String
  country      String
  raceDate     DateTime
  sprintDate   DateTime?
  pickDeadline DateTime
  results      RaceResult[]
  picks        Pick[]

  @@unique([season, round])
}

model Pick {
  id        String   @id @default(cuid())
  userId    String
  poolId    String
  raceId    String
  driverId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool      Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId, raceId])
}

model RaceResult {
  id            String  @id @default(cuid())
  raceId        String
  driverId      String
  position      Int?
  racePoints    Float   @default(0)
  sprintPoints  Float   @default(0)
  fastestLap    Boolean @default(false)
  totalPoints   Float   @default(0)
  race          Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driver        Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([raceId, driverId])
}
